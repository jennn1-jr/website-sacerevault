generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// SQLite does not support enums, using String instead

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  name             String
  passwordHash     String // Hashed with bcrypt
  publicKey        String // RSA-4096 Public Key (PEM)
  encryptedPrivKey String // RSA-4096 Private Key terenkripsi (AES)
  role             String   @default("USER")
  createdAt        DateTime @default(now())

  documents      Document[]       @relation("DocumentOwner")
  sharedAccess   SharedAccess[]
  activityLogs   ActivityLog[]
  sessions       Session[]
  notifications  Notification[]
  TemporaryShare TemporaryShare[]
  Device         Device[]
}

model Document {
  id           String @id @default(uuid())
  title        String
  originalName String
  mimeType     String
  size         BigInt
  storagePath  String @unique
  fileHash     String // SHA-256 hash
  signature    String // Digital Signature
  status       String @default("ACTIVE")

  ownerId String
  owner   User   @relation("DocumentOwner", fields: [ownerId], references: [id])

  sharedAccess   SharedAccess[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  TemporaryShare TemporaryShare[]
}

model SharedAccess {
  id               String    @id @default(uuid())
  documentId       String
  userId           String
  encryptedFileKey String // AES Key untuk file ini, dienkripsi via RSA Public Key penerima
  grantedBy        String // ID pengirim
  expiresAt        DateTime?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String
  action     String // LOGIN, UPLOAD, DOWNLOAD, SHARE, DELETE
  resourceId String? // Document ID terkait
  ipAddress  String?
  userAgent  String?
  status     String // SUCCESS, FAILED
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  isValid      Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TemporaryShare {
  id          String   @id @default(uuid())
  documentId  String
  createdBy   String
  token       String   @unique
  accessCount Int      @default(0)
  maxAccess   Int      @default(100)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  isActive    Boolean  @default(true)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  creator  User     @relation(fields: [createdBy], references: [id])

  @@index([token])
  @@index([documentId])
}

model Device {
  id         String   @id @default(uuid())
  userId     String
  deviceName String
  deviceId   String   @unique
  publicKey  String // For WebRTC connection
  lastSeen   DateTime @updatedAt
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String // e.g., 'SHARE_CODE'
  data      String? // JSON string containing the share code/token
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
